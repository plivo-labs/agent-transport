{
  "name": "agent-transport",
  "version": "0.1.7",
  "description": "SIP and audio streaming transport for AI voice agents (pure Rust)",
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT",
  "exports": {
    ".": {
      "import": "./index.js",
      "types": "./index.d.ts"
    },
    "./livekit": {
      "import": "./livekit/index.js",
      "types": "./livekit/index.d.ts"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "livekit/",
    "README.md"
  ],
  "napi": {
    "binaryName": "agent-transport",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "CMAKE_POLICY_VERSION_MINIMUM=3.5 napi build --release --no-js",
    "build:debug": "CMAKE_POLICY_VERSION_MINIMUM=3.5 napi build --no-js",
    "build:livekit": "tsc -p tsconfig.livekit.json",
    "build:all": "npm run build && npm run build:livekit"
  },
  "peerDependencies": {
    "@livekit/agents": ">=1.2.0",
    "@livekit/rtc-node": ">=0.13.0"
  },
  "peerDependenciesMeta": {
    "@livekit/agents": { "optional": true },
    "@livekit/rtc-node": { "optional": true }
  },
  "devDependencies": {
    "@napi-rs/cli": "^3",
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "@livekit/agents": ">=1.2.0",
    "@livekit/rtc-node": ">=0.13.0"
  }
}
